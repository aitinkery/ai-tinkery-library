modules = ["web", "nodejs-20", "python-3.12"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Run Library"

[[workflows.workflow]]
name = "Run Library"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start library server"

[[workflows.workflow]]
name = "Start library server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python server.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python", "server.py"]
